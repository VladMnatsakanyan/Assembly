#include <stdio.h>

int main(void) {
    int N, K;
    int a[21], b[21];
    scanf("%d %d", &N, &K);

    a[0] = 1;
    for (int i = 1; i <= N; i++) {
        b[0] = 1;
        for (int j = 1; j < i; j++) {
            b[j] = a[j] + a[j - 1];
        }
        b[i] = 1;
        for (int j = 0; j <= i; j++) {
            a[j] = b[j];
        }
    }

    printf("%d\n", a[K]);

    return 0;
}
